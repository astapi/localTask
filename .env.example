# Notion Integration Token (https://www.notion.so/my-integrations)
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 同期対象のデータソースID（新Notion API: 2025-09-03以降）
# 取得方法: インテグレーションを元DBに接続後、search APIで data_source の id を確認
NOTION_DATA_SOURCE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# 絞り込み（任意）: 指定したselect型プロパティが指定値のタスクだけ取得
# 例: Project = Pody。NOTION_FILTER_VALUE を空にすると全件取得
NOTION_FILTER_PROPERTY=Project
NOTION_FILTER_VALUE=Pody

# Notionプロパティ名のマッピング（あなたのDBに合わせて変更）
# タイトル列の名前は自動検出するので通常は不要
NOTION_PROP_STATUS=Status
NOTION_PROP_DUE=Due date
NOTION_PROP_PRIORITY=Priority
NOTION_PROP_ASSIGNEE=Assignee

# 「完了」とみなすステータス値（カンマ区切り）
DONE_STATUSES=Done,完了,Complete,Closed

# Slack Incoming Webhook URL（サマリ通知の送信先）
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz

# SQLite DBの保存先（省略時は ./data/localtask.db）
LOCALTASK_DB=
